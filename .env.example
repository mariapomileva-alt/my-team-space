# Copy to .env.local for local dev:  cp .env.example .env.local
# Get values from Supabase → Project Settings → API → anon public key + Project URL

NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...paste-full-anon-key-here

# Optional (same values; used on server in production)
SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
SUPABASE_ANON_KEY=eyJ...paste-full-anon-key-here
